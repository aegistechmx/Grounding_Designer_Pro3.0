# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grounding_saas
DB_USER=postgres
DB_PASSWORD=your_password_here

# Redis Configuration (for BullMQ job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
SKIP_REDIS=true  # Set to true to skip Redis for debugging

# JWT Configuration
JWT_SECRET=grounding-designer-pro-secret-key-change-in-production-2024
JWT_EXPIRES_IN=7d

# S3/Storage Configuration (AWS S3 or MinIO)
USE_LOCAL_STORAGE=true
S3_BUCKET=grounding-designer-pro
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Email Configuration (Resend)
RESEND_API_KEY=re_test_placeholder_key
EMAIL_FROM=noreply@groundingdesignerpro.com
EMAIL_FROM_NAME=Grounding Designer Pro

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
