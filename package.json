{
  "name": "grounding-designer-pro",
  "version": "3.0.0",
  "description": "Grounding Designer Pro 3.0 - Sistema Profesional de Diseño de Mallas de Tierra",
  "author": "Proyectos Integrales",
  "main": "main.js",
  "scripts": {
    "start": "node --max-old-space-size=4096 node_modules/react-scripts/scripts/start.js",
    "build": "react-scripts build",
    "dist": "npm run build && electron-builder --win",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --maxWorkers=2",
    "server": "node server/index.js"
  },
  "dependencies": {
    "@tootallnate/once": "^3.0.1",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "firebase": "^12.12.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "nth-check": "^2.1.1",
    "pg": "^8.11.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1",
    "serialize-javascript": "^7.0.5",
    "three": "^0.184.0",
    "webpack-dev-server": "^5.2.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.10",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.1",
    "webpack-bundle-analyzer": "^5.3.0"
  },
  "build": {
    "appId": "com.grounding.designer.pro",
    "productName": "Grounding Designer Pro 3.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "main.js",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    }
  },
  "homepage": "./",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
